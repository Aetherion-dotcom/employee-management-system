{
  "info": {
    "name": "WorkForceHub API Collection",
    "description": "Complete API collection for WorkForceHub Employee Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usernameOrEmail\": \"admin\",\n  \"password\": \"Admin@123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = pm.response.json();",
                "if(jsonData.data) {",
                "  pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
                "  pm.collectionVariables.set('refreshToken', jsonData.data.refreshToken);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"johndoe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh-token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@workforcehub.com\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/employees?page=0&size=10&sortBy=id&sortDir=asc", "host": ["{{baseUrl}}"], "path": ["employees"], "query": [{"key":"page","value":"0"},{"key":"size","value":"10"},{"key":"sortBy","value":"id"},{"key":"sortDir","value":"asc"}] },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Get Employee by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/employees/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/employees",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"email\": \"jane.smith@company.com\",\n  \"phone\": \"+1234567890\",\n  \"gender\": \"FEMALE\",\n  \"designation\": \"Software Engineer\",\n  \"joiningDate\": \"2024-01-15\",\n  \"departmentId\": 1,\n  \"salary\": 85000.00,\n  \"status\": \"ACTIVE\"\n}"
            }
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/employees/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith-Updated\",\n  \"email\": \"jane.smith@company.com\",\n  \"designation\": \"Senior Software Engineer\",\n  \"joiningDate\": \"2024-01-15\",\n  \"departmentId\": 1,\n  \"salary\": 95000.00,\n  \"status\": \"ACTIVE\"\n}"
            }
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/employees/2",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Search Employees",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/employees?search=john", "host": ["{{baseUrl}}"], "path": ["employees"], "query": [{"key":"search","value":"john"}] },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Departments",
      "item": [
        {
          "name": "Get All Departments",
          "request": { "method": "GET", "url": "{{baseUrl}}/departments", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] }
        },
        {
          "name": "Create Department",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/departments",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Research\",\n  \"code\": \"RES\",\n  \"description\": \"Research and Development\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "Check In",
          "request": { "method": "POST", "url": "{{baseUrl}}/attendance/check-in/1", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] }
        },
        {
          "name": "Check Out",
          "request": { "method": "POST", "url": "{{baseUrl}}/attendance/check-out/1", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Analytics",
          "request": { "method": "GET", "url": "{{baseUrl}}/dashboard", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }] }
        }
      ]
    }
  ]
}
